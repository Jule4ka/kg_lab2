<#Course> 
    a               rdfs:Class ;
    rdfs:label      "course" ;
    rdfs:comment    "A structured series of lessons or classes on a particular subject, usually designed to teach specific knowledge or skills at an educational institution." .

<#Student> 
    a               rdf:Class ;
    a               <#Person> ;
    rdfs:label      "student"@en ;
    rdfs:comment    "a person who enrolls in an educational program or course"@en .

<#Micro-credential-student> 
    a               rdfs:Class ;
    rdfs:label      "micro-credential student"@en ;
    rdfs:comment    "a student who enrolls in a short, focused educational program designed to build a specific skill or competency"@en .

<#student-enrolment-type> 
    a               rdf:Property ;
    rdfs:label      "student enrolment type"@en ;
    rdfs:comment    "the category under which a student is officially registered at an educational institution"@en ;
    rdfs:domain     <#Student> ;
    rdfs:range      rdfs:Resource .

<#enrolledIn>
    a               rdf:Property ;
    rdfs:label      "enrolled in" ;
    rdfs:comment    "Formally registered as a participant in a course." ;
    rdfs:domain     <#Student> ;
    rdfs:range      <#Course> .


#      _                                       _       
#     | |                                     | |      
#   __| | ___   ___ _   _ _ __ ___   ___ _ __ | |_ ___ 
#  / _` |/ _ \ / __| | | | '_ ` _ \ / _ \ '_ \| __/ __|
