<#Img> 
    a                   rdf:Class ;
    rdfs:subClassOf     foaf:Image ;
    rdfs:label          "photograph"@en ;
    rdfs:comment        "A two-dimensional visual representation of a moment captured using a camera."@en .

<#imageURL>
    a                   rdf:Property ;
    rdfs:subPropertyOf  schema:url ;
    rdfs:label          "content url"@en ;
    rdfs:comment        "The online location of an image."@en ;
    rdfs:domain         <#Img> ;
    rdfs:range          schema:URL .

<#photographer>
    a                   rdf:Property ;
    rdfs:subPropertyOf  foaf:maker ;
    rdfs:label          "photographer"@en ;
    rdfs:comment        "The person who created an image by capturing a moment with a camera."@en ;
    rdfs:domain         <#Img> ;
    rdfs:range          <#Person> .

<#portrays>
    a                   rdf:Property ;
    rdfs:subPropertyOf  foaf:depicts ;
    rdfs:label          "portrays"@en ;
    rdfs:comment        "Someone that is visible on an image."@en ;
    rdfs:domain         <#Img> ;
    rdfs:range          <#Person> .

<#shooting-location>
    a                   rdf:Property ;
    rdfs:subPropertyOf  schema:contentLocation ;
    rdfs:label          "shooting location"@en ;
    rdfs:comment        "The place where the image was taken."@en ;
    rdfs:domain         <#Img> ;
    rdfs:range          <#Location> .