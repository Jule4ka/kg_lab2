@base   <https://janaverl.github.io/knowledge_graphs_lab2/vocabulary.ttl> .

@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix foaf:   <http://xmlns.com/foaf/0.1/> .
@prefix schema: <https://schema.org/> .

#   __ _  ___ _ __   ___ _ __ __ _| |
#  / _` |/ _ \ '_ \ / _ \ '__/ _` | |
# | (_| |  __/ | | |  __/ | | (_| | |
#  \__, |\___|_| |_|\___|_|  \__,_|_|
#   __/ |                            
#  |___/                             

<#Person> 
    a                   rdf:Class ;
    rdfs:subClassOf     foaf:Person ;
    rdfs:label          "person"@en ;
    rdfs:comment        "a human being"@en .

<#Location>
    a                   rdf:Class ;
    rdfs:subClassOf     schema:Place ;
    rdfs:label          "location"@en ;
    rdfs:comment        "identification for a place, a building or region."@en .

<#name> 
    a                   rdf:Property ;
    rdfs:subPropertyOf  foaf:name ;
    rdfs:label          "name"@en ;
    rdfs:comment        "a word or set of words by which a person, a thing or a place is known or addressed"@en ;
    rdfs:domain         rdfs:Resource ;
    rdfs:range          rdfs:Literal .

<#e-mail> 
    a                   rdf:Property ;
    rdfs:label          "e-mail"@en ;
    rdfs:comment        "a unique identifier that specifies the address of a digital mailbox where electronic messages can be sent and received"@en ;
    rdfs:domain         rdfs:Resource ;
    rdfs:range          rdfs:Literal .

<#knows> 
    a                   rdf:Property ;
    rdfs:subPropertyOf  foaf:knows ;
    rdfs:label          "knows"@en ;
    rdfs:comment        "having some degree of personal awareness of that person based on prior interaction, experience, or information"@en ;
    rdfs:domain         <#Person> ;
    rdfs:range          <#Person> .

<#description> 
    a                   rdf:Property ;
    rdfs:subPropertyOf  rdfs:comment ;
    rdfs:label          "description"@en ;
    rdfs:comment        "An explanation that tells what something is, so someone can imagine or understand it."@en ;
    rdfs:domain         rdfs:Resource ;
    rdfs:range          rdfs:Literal .

#   __                _                _      _       _        
#  / _|              | |   ___        | |    (_)     | |       
# | |_ ___   ___   __| |  ( _ )     __| |_ __ _ _ __ | | _____ 
# |  _/ _ \ / _ \ / _` |  / _ \/\  / _` | '__| | '_ \| |/ / __|
# | || (_) | (_) | (_| | | (_>  < | (_| | |  | | | | |   <\__ \
# |_| \___/ \___/ \__,_|  \___/\/  \__,_|_|  |_|_| |_|_|\_\___/

<#Drink> 
    a               rdfs:Class ;
    rdfs:label      "drink"@en ;
    rdfs:comment    "liquid consumed by a person to hydrate, provide nourishment, or offer sensory enjoyment"@en .

<#Coffee> 
    a               rdfs:Class ;
    a               <#Drink> ;
    rdfs:label      "coffee"@en ;
    rdfs:comment    "a hot beverage brewed from roasted seeds of the coffee plant, known for its dark color, bitter taste, and stimulating caffeine content"@en .

<#favorite-drink> 
    a               rdf:Property ;
    rdfs:label      "favorite drink"@en ;
    rdfs:comment    "the beverage a person most enjoys choosing and consuming above all others"@en ;
    rdfs:domain     <#Person> ;
    rdfs:range      <#Drink> .
    
#   __                 _   _                
#  / _|               | | (_)               
# | |_ _ __ ___  ___  | |_ _ _ __ ___   ___ 
# |  _| '__/ _ \/ _ \ | __| | '_ ` _ \ / _ \
# | | | | |  __/  __/ | |_| | | | | | |  __/
# |_| |_|  \___|\___|  \__|_|_| |_| |_|\___|

<#Activity> 
    a               rdfs:Class ;
    rdfs:label      "activity"@en ;
    rdfs:comment    "a thing that somebody spends time doing"@en .

<#Running> 
    a               rdfs:Class ;
    a               <#Activity> ;
    rdfs:label      "running"@en ;
    rdfs:comment    "a physical activity in which a person moves forward on foot at a speed faster than walking, with moments when both feet are off the ground"@en .

<#hobby> 
    a               rdf:Property ;
    rdfs:label      "hobby"@en ;
    rdfs:comment    "an activity someone chooses to do regularly for enjoyment, interest or personal satisfaction"@en ;
    rdfs:domain     <#Person> ;
    rdfs:range      <#Activity> .


#      _             _       
#     | |           | |      
#  ___| |_ _   _  __| |_   _ 
# / __| __| | | |/ _` | | | |
# \__ \ |_| |_| | (_| | |_| |
# |___/\__|\__,_|\__,_|\__, |
#                       __/ |
